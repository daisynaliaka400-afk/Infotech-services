# =============================================================
# Infotech Internet Services — Environment Variables
# =============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================

# ── Supabase ──────────────────────────────────────────────────
# Your Supabase project URL (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anon/public key (safe for frontend use)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── GiftedPay (set as Supabase Secret — NOT here) ─────────────
# Run: supabase secrets set GIFTEDPAY_API_KEY=your_actual_key
# This must NEVER be exposed to the frontend.
